# Root .dockerignore — applies to the BACKEND build (context = repo root).
# (The frontend build uses frontend/.dockerignore with context = frontend/.)

# Git / IDE
.git/
.github/
.vscode/
.idea/

# Python envs & caches
backend/venv/
backend/.venv/
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
.pytest_cache/
.mypy_cache/

# Frontend (not part of the backend image)
frontend/node_modules/
frontend/dist/
node_modules/

# Local runtime artifacts
**/*.log
backend/uploads/

# Secrets & docs
.env
*.md
infra/

# Tests
backend/tests/
