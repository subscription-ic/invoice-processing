# Force LF for files that run inside Linux containers — CRLF would break them
# (e.g. "bad interpreter" errors on shell scripts).
*.sh            text eol=lf
entrypoint.sh   text eol=lf
Dockerfile      text eol=lf
*.dockerignore  text eol=lf
docker-compose.yml text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
