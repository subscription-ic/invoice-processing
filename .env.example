# Database
POSTGRES_USER=apuser
POSTGRES_PASSWORD=appassword
POSTGRES_DB=ap_platform
DATABASE_URL=postgresql+asyncpg://apuser:appassword@db:5432/ap_platform
SYNC_DATABASE_URL=postgresql://apuser:appassword@db:5432/ap_platform

# Redis
REDIS_PASSWORD=redispassword
REDIS_URL=redis://:redispassword@redis:6379/0

# Security
SECRET_KEY=supersecretkey-change-in-production-32chars-minimum
ACCESS_TOKEN_EXPIRE_MINUTES=480

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# Application
ENVIRONMENT=development
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,docx,tiff

# Frontend
VITE_API_URL=http://localhost:8000

# Celery
CELERY_BROKER_URL=redis://:redispassword@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redispassword@redis:6379/1

# Future: Azure
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=documents
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Future: Email Ingestion
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# Future: Teams
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=

# Matching Tolerances (%)
PRICE_TOLERANCE_PERCENT=2.0
QUANTITY_TOLERANCE_PERCENT=0.0
TAX_TOLERANCE_PERCENT=1.0
